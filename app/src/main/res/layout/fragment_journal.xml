<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_16">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/journal_title"
            android:textAppearance="@style/TextAppearance.Headline"
            android:textColor="@color/accent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_12"
            android:orientation="horizontal"
            android:spacing="@dimen/margin_8">

            <Button
                android:id="@+id/export_log_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/shape_rounded_button"
                android:text="@string/export_log"
                android:textColor="@color/text_inverse"
                android:textSize="@dimen/text_small" />

            <Button
                android:id="@+id/clear_log_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/shape_rounded_button"
                android:text="@string/clear_log"
                android:textColor="@color/text_inverse"
                android:textSize="@dimen/text_small" />
        </LinearLayout>
    </LinearLayout>

    <!-- Emergency Events List -->
    <RecyclerView
        android:id="@+id/events_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="@dimen/padding_16" />

    <!-- Empty State -->
    <TextView
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="@string/journal_empty"
        android:textAppearance="@style/TextAppearance.Body"
        android:textColor="@color/text_secondary"
        android:visibility="gone" />
</LinearLayout>