<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_16">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/home_title"
            android:textAppearance="@style/TextAppearance.Headline"
            android:textColor="@color/accent" />

        <!-- AI Face Container -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/ai_face_size"
            android:layout_marginVertical="@dimen/margin_24"
            android:background="@drawable/shape_circular_progress">

            <ImageView
                android:id="@+id/ai_face"
                android:layout_width="@dimen/ai_face_size"
                android:layout_height="@dimen/ai_face_size"
                android:layout_gravity="center"
                android:contentDescription="@string/app_name"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_home" />
        </FrameLayout>

        <!-- Threat Level Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/margin_16"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/corner_large"
            app:cardElevation="4dp"
            app:strokeColor="@color/outline"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_16">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/threat_level"
                    android:textAppearance="@style/TextAppearance.Title"
                    android:textColor="@color/text_primary" />

                <!-- Threat Level Indicator -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_12"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/threat_level_text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/threat_safe"
                        android:textAppearance="@style/TextAppearance.Display"
                        android:textColor="@color/threat_safe" />

                    <ProgressBar
                        android:id="@+id/threat_level_progress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="4"
                        android:progress="0" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Status Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/margin_16"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/corner_large"
            app:cardElevation="4dp"
            app:strokeColor="@color/outline"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_16">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_marginRight="@dimen/margin_12"
                        android:background="@drawable/shape_circular_progress"
                        android:id="@+id/status_indicator" />

                    <TextView
                        android:id="@+id/status_text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/status_online"
                        android:textAppearance="@style/TextAppearance.Body"
                        android:textColor="@color/text_primary" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Emergency SOS Button -->
        <Button
            android:id="@+id/emergency_button"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:background="@drawable/shape_rounded_button"
            android:text="@string/emergency_button"
            android:textColor="@color/text_inverse"
            android:textSize="@dimen/text_title"
            android:textStyle="bold" />

        <!-- Guardian Control Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_16"
            android:orientation="horizontal"
            android:spacing="@dimen/margin_12">

            <Button
                android:id="@+id/start_guardian_btn"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_weight="1"
                android:background="@drawable/shape_rounded_button"
                android:text="@string/start_guardian"
                android:textColor="@color/text_inverse" />

            <Button
                android:id="@+id/stop_guardian_btn"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_weight="1"
                android:background="@drawable/shape_rounded_button"
                android:text="@string/stop_guardian"
                android:textColor="@color/text_inverse" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>