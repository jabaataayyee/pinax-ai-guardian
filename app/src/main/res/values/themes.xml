<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Theme.PinaxGuardian" parent="Theme.AppCompat.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>

        <!-- Custom colors -->
        <item name="android:colorBackground">@color/background</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/background</item>

        <!-- Material buttons -->
        <item name="buttonStyle">@style/Widget.Button.Pinax</item>
        <item name="materialButtonStyle">@style/Widget.MaterialButton.Pinax</item>
    </style>

    <!-- Custom Button Styles -->
    <style name="Widget.Button.Pinax" parent="Widget.AppCompat.Button">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_md</item>
        <item name="android:padding">@dimen/padding_md</item>
        <item name="android:background">@drawable/btn_background</item>
    </style>

    <style name="Widget.MaterialButton.Pinax" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">@dimen/corner_radius_md</item>
        <item name="backgroundTint">@color/accent</item>
    </style>

    <!-- Text Styles -->
    <style name="TextStyle.Heading1">
        <item name="android:textSize">@dimen/text_3xl</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextStyle.Heading2">
        <item name="android:textSize">@dimen/text_2xl</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextStyle.Body">
        <item name="android:textSize">@dimen/text_md</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextStyle.Caption">
        <item name="android:textSize">@dimen/text_sm</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

</resources>