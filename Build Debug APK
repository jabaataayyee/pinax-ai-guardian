name: Build Debug APK

on:
  push:
    branches:
      - main
      - develop
  pull_request:
    branches:
      - main
      - develop
  workflow_dispatch:

jobs:
  build-debug-apk:
    runs-on: ubuntu-latest
    
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Set up JDK 11
        uses: actions/setup-java@v3
        with:
          java-version: '11'
          distribution: 'temurin'

      - name: Build debug APK
        run: |
          chmod +x gradlew
          ./gradlew clean assembleDebug
        env:
          GRADLE_OPTS: "-Xmx2048m"

      - name: Verify APK was created
        run: |
          APK_PATH="app/build/outputs/apk/debug/app-debug.apk"
          
          if [ -f "$APK_PATH" ]; then
            echo "✅ Debug APK found"
            echo "📦 APK size: $(du -h "$APK_PATH" | cut -f1)"
            ls -lh "$APK_PATH"
          else
            echo "❌ Debug APK not found"
            find app/build/outputs -name "*.apk" -type f 2>/dev/null
            exit 1
          fi

      - name: Upload debug APK artifact
        uses: actions/upload-artifact@v3
        if: success()
        with:
          name: pinax-guardian-debug-apk
          path: app/build/outputs/apk/debug/app-debug.apk
          retention-days: 30

      - name: Build Summary
        run: |
          echo ""
          echo "╔════════════════════════════════════════╗"
          echo "║   ✅ DEBUG APK BUILD SUCCESSFUL       ║"
          echo "╚════════════════════════════════════════╝"
          echo ""
          echo "📦 Artifact: pinax-guardian-debug-apk"
          echo "🚀 Download from: Actions Artifacts tab"
          echo "⚡ No signing required"
          echo "🔧 Ready for testing & development"
          echo ""
